{
  "name": "nexusflow-backend",
  "version": "1.0.0",
  "description": "NexusFlow CRM Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src -e ts,json --exec \"ts-node --transpile-only src/index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "ts-node": {
    "transpileOnly": true,
    "esModuleInterop": true
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.1",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
